{
  "functions": {
    "src/app/api/ai/**": {
      "maxDuration": 60
    },
    "src/app/api/webhooks/**": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-resumes",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/publish-salary-pages",
      "schedule": "0 9 */2 * *"
    },
    {
      "path": "/api/cron/retry-distributions",
      "schedule": "0 * * * *"
    }
  ]
}
