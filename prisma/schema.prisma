generator client {
  provider   = "prisma-client-js"
  engineType = "wasm"
}

datasource db {
  provider = "postgresql"
}

enum ClaimedStatus {
  UNCLAIMED
  CLAIMED
}

model Organization {
  id                   String        @id @default(cuid())
  name                 String
  slug                 String        @unique
  plan                 Plan          @default(FREE)
  claimedStatus        ClaimedStatus @default(CLAIMED)
  claimToken           String?       @unique // one-time token to claim an unclaimed org
  claimTokenExpiresAt  DateTime?
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique
  aiCreditsBalance     Int           @default(100)
  aiCreditsResetAt     DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  members        Member[]
  jobs           Job[]
  candidates     Candidate[]
  pipelines      Pipeline[]
  emailTemplates EmailTemplate[]
  invitations    Invitation[]
  feedbacks      Feedback[]
  communications Communication[]
  integrations   Integration[]
}

enum Plan {
  FREE
  PRO
}

model Member {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           Role         @default(MEMBER)
  token          String       @unique @default(cuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
}

model Feedback {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  userEmail      String
  type           FeedbackType
  title          String
  description    String?      @db.Text
  votes          Int          @default(0)
  voterIds       String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

enum FeedbackType {
  FEATURE
  BUG
}

model Job {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String       @db.Text
  requirements   String?      @db.Text
  location       String?
  streetAddress  String?
  postalCode     String?
  salaryMin      Int?
  salaryMax      Int?
  status         JobStatus    @default(DRAFT)
  slug           String?
  extraDetails   String?      @db.Text
  pipelineId     String
  pipeline       Pipeline     @relation(fields: [pipelineId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  applications      Application[]
  communications    Communication[]
  jobDistributions  JobDistribution[]

  @@index([organizationId])
  @@index([pipelineId])
  @@unique([organizationId, slug])
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

model Pipeline {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  stages Stage[]
  jobs   Job[]

  @@index([organizationId])
}

model Stage {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  color      String   @default("#6366f1")
  createdAt  DateTime @default(now())

  applications Application[]

  @@index([pipelineId])
}

model Candidate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  email          String
  phone          String?
  resumeUrl      String?
  resumeText     String?      @db.Text
  resumeExpiresAt DateTime?
  linkedinUrl    String?
  tags           String[]     @default([])
  summary        String?      @db.Text
  workExperience Json?
  achievements   String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  applications   Application[]
  notes          Note[]
  aiSummary      AiSummary?
  communications Communication[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Application {
  id                   String    @id @default(cuid())
  jobId                String
  job                  Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId          String
  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  stageId              String
  stage                Stage     @relation(fields: [stageId], references: [id])
  aiScore              Int?
  aiGapAnalysis        Json?
  aiInterviewQuestions Json?
  aiReferenceQuestions String[]  @default([])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([jobId, candidateId])
  @@index([stageId])
  @@index([jobId])
  @@index([candidateId])
}

model Note {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId    String
  content     String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([candidateId])
}

model AiSummary {
  id          String    @id @default(cuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  summary     String    @db.Text
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
}

model EmailTemplate {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  type           EmailTemplateType @default(CUSTOM)
  subject        String
  body           String            @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
}

enum EmailTemplateType {
  CONFIRMATION
  CUSTOM
}

model AppAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  actorEmail String
  action     String
  entityType String
  entityId   String
  entityName String?
  metadata   Json?
  orgId      String?

  @@index([createdAt])
  @@index([actorEmail])
  @@index([orgId])
}

model SalaryEntry {
  citySlug           String
  roleSlug           String
  cityName           String
  stateName          String
  country            String   @default("US")
  roleName           String
  category           String
  localSalaryLow     Int
  localSalaryMedian  Int
  localSalaryHigh    Int
  remoteSalaryLow    Int
  remoteSalaryMedian Int
  remoteSalaryHigh   Int
  savingsPercent     Int
  annualSavings      Int
  currency           String   @default("USD")
  dataYear           Int      @default(2025)
  demandLevel        String   @default("medium")
  publishedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@id([citySlug, roleSlug])
  @@index([citySlug])
  @@index([roleSlug])
  @@index([publishedAt])
  @@index([category])
}

model CronLog {
  id         String   @id @default(cuid())
  job        String
  status     String
  message    String?
  details    Json?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([job])
  @@index([createdAt])
}

model GeneratedBlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     Json
  category    String
  readingTime String
  planDay     Int      @unique
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([planDay])
  @@index([publishedAt])
}

enum EmailType {
  OUTREACH
  INTERVIEW_INVITE
  FOLLOW_UP
  OFFER
  REJECTION
}

// ============ FEATURE FLAGS ============

enum FlagRollout {
  DISABLED
  ADMINS
  EVERYONE
}

model FeatureFlag {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String?
  rollout     FlagRollout @default(DISABLED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([key])
}

// ============ PLATFORM-LEVEL INTEGRATIONS ============
// Used for KiteHR's own connections (e.g. posting blog content to the KiteHR
// LinkedIn company page). Not tied to any client organization.

model PlatformIntegration {
  id             String    @id @default(cuid())
  platform       String    @unique  // e.g. "linkedin_blog"
  accessToken    String?   @db.Text
  refreshToken   String?   @db.Text
  tokenExpiresAt DateTime?
  externalId     String?   // LinkedIn organization URN
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============ JOB DISTRIBUTION ============

model Integration {
  id             String    @id @default(cuid())
  organizationId String
  platform       String    // "linkedin" | "indeed_feed"
  accessToken    String?   @db.Text
  refreshToken   String?   @db.Text
  tokenExpiresAt DateTime?
  externalId     String?   // LinkedIn organization URN
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platform])
  @@index([organizationId])
}

model JobDistribution {
  id            String    @id @default(cuid())
  jobId         String
  platform      String    // "linkedin" | "indeed_feed"
  status        String    // "pending" | "distributed" | "failed" | "closed"
  externalJobId String?   // LinkedIn jobPosting URN
  errorMessage  String?   @db.Text
  retryCount    Int       @default(0)
  distributedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, platform])
  @@index([jobId])
  @@index([status])
}


// ============ OUTREACH ============

model OutreachLead {
  id             String   @id @default(cuid())
  companyName    String
  website        String?
  contactEmail   String?
  contactName    String?
  source         String   // "hn_hiring" | "manual" | "reddit" | "csv" | "product_hunt" | "yc"
  sourceUrl      String?
  hiringFor      String?  @db.Text
  companyStage   String?  // "startup" | "smb" | "enterprise"
  status         String   @default("new") // "new" | "contacted" | "bounced" | "responded" | "converted" | "unsubscribed"
  notes          String?  @db.Text
  lastContactedAt DateTime?
  claimToken          String?  @unique
  claimTokenExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  emails         OutreachEmail[]

  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model OutreachEmail {
  id        String   @id @default(cuid())
  leadId    String
  subject   String
  body      String   @db.Text
  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?
  resendId  String?
  createdAt DateTime @default(now())
  lead      OutreachLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ============ GOOGLE INDEXING ============

model GoogleIndexingLog {
  id           String   @id @default(cuid())
  url          String
  type         String   @default("URL_UPDATED") // URL_UPDATED | URL_DELETED
  status       String   // "success" | "error"
  httpStatus   Int?
  response     Json?
  errorMessage String?  @db.Text
  submittedBy  String
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([url])
}

model Communication {
  id             String       @id @default(cuid())
  candidateId    String
  candidate      Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobId          String?
  job            Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  type           EmailType
  subject        String
  body           String       @db.Text
  authorId       String
  createdAt      DateTime     @default(now())

  @@index([candidateId])
  @@index([organizationId])
}
