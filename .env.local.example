# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourapp.com

# Cloudflare R2 (resume storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=resumes

# Cron (used by /api/cron/cleanup-resumes)
CRON_SECRET=your-secret-cron-token

# Amplitude Analytics
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reddit Auto-Commenter (Admin > Reddit Commenter)
# No API credentials needed — uses Reddit's public JSON API for reading posts.
# Enable from the admin panel and copy-paste generated drafts manually on Reddit.

# LinkedIn OAuth (Job Distribution — enable via Admin > Feature Flags)
# Create an app at https://developer.linkedin.com and request r_organization_admin, rw_organization_admin, w_member_social, w_organization_social scopes
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/integrations/linkedin/callback

# LinkedIn Blog Sharing — set to the Organization ID of your KiteHR company in the DB
# so the daily blog cron can find the connected LinkedIn integration and post to your company page
KITEHR_ORGANIZATION_ID=
